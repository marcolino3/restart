{
  "name": "@restart/backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "clean": "rm -rf dist coverage",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "pnpm typeorm migration:generate -d src/data-source.ts",
    "migration:create": "pnpm typeorm migration:create",
    "migration:run": "pnpm typeorm migration:run -d src/data-source.ts",
    "migration:revert": "pnpm typeorm migration:revert -d src/data-source.ts",
    "migration:show": "pnpm typeorm migration:show -d src/data-source.ts",
    "migration:run:prod": "node dist/src/migrate.js"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@better-auth/expo": "^1.6.11",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.1.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.15",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.15",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@sentry/nestjs": "^10.53.1",
    "@sentry/profiling-node": "^10.53.1",
    "@thallesp/nestjs-better-auth": "^2.6.0",
    "@types/luxon": "^3.7.1",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.6.11",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
