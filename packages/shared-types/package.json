{
  "name": "@restart/shared-types",
  "version": "0.0.1",
  "private": true,
  "description": "Generated GraphQL types + document tags shared by web and mobile apps",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./graphql": "./src/graphql.ts",
    "./gql": "./src/gql.ts",
    "./fragment-masking": "./src/fragment-masking.ts"
  },
  "scripts": {
    "clean": "rm -rf src/graphql.ts src/gql.ts src/fragment-masking.ts src/index.ts"
  },
  "peerDependencies": {
    "graphql": "^16.0.0"
  },
  "dependencies": {
    "@graphql-typed-document-node/core": "^3.2.0"
  }
}
