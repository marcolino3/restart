{
  "name": "@restart/shared-i18n",
  "version": "0.0.1",
  "private": true,
  "description": "Shared i18n message catalogs (DE, EN) used by web and mobile apps",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./messages/de": "./messages/de.json",
    "./messages/en": "./messages/en.json",
    "./messages/*": "./messages/*.json"
  },
  "files": [
    "src",
    "messages"
  ]
}
