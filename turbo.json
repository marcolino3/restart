{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "**/.env",
    "**/.env.*"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "CI"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "app/**",
        "components/**",
        "lib/**",
        "hooks/**",
        "messages/**",
        "public/**",
        "gql/**",
        "i18n/**",
        "nest-cli.json",
        "next.config.*",
        "tsconfig*.json",
        "postcss.config.*",
        "tailwind.config.*",
        "package.json"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "codegen": {
      "cache": false,
      "outputs": ["gql/**"]
    },
    "format": {
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
